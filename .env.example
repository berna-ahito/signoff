SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=sqlite:///./procureflow.db

# AI provider: "mock" (default, no API key needed) or "groq" (free tier)
AI_PROVIDER=mock
GROQ_API_KEY=

# Optional Slack webhook for high-risk and approval notifications (leave blank to disable)
SLACK_WEBHOOK_URL=

# Set to "production" to disable /docs, /redoc, /openapi.json
APP_ENV=development
