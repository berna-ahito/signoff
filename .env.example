SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# SQLite (local dev):
DATABASE_URL=sqlite:///./procureflow.db
# PostgreSQL / Neon (production) — replace with your actual Neon connection string:
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/procureflow?sslmode=require

# AI provider: "mock" (default, no API key needed) or "groq" (free tier)
AI_PROVIDER=mock
GROQ_API_KEY=

RESEND_API_KEY=

# Set to "production" to disable /docs, /redoc, /openapi.json
APP_ENV=development

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
